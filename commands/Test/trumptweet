const Discord = require("discord.js");
const { MessageEmbed } = require("discord.js");


module.exports = {
    name: "trumptweet",
  description: "text to tweet trump",
  usage: "tweet [username] [text]",
  enabled: false,
  aliases: [""],
  category: "Utility",
  memberPermissions: [],
  botPermissions: [ "SEND_MESSAGES", "EMBED_LINKS" ],
  //Settings for command
  nsfw: false,
  ownerOnly: true,
  cooldown: 0,

    async execute(client, message, args, data){
        if (message.author.bot === false) {
            const result = arguments.join('+')
            const url = `https://api.no-api-key.com/api/v2/trump?message=${result}`;

            const embed = new MessageEmbed().setImage(url).setColor("RANDOM");

            await message.channel.send(embed);
        }

    }
}