const { MessageEmbed } = require('discord.js')
const RankSchema = require('../../models/ranks')

module.exports = {
    name: "rank",
    description: "Shows your text as Clyde\'s message",
    usage: "clyde <text>",
    enabled: true,
    aliases: [],
    category: "Fun",
    memberPermissions: [],
    botPermissions: ["SEND_MESSAGES", "EMBED_LINKS"],
    //Settings for command
    nsfw: false,
    ownerOnly: false,
    cooldown: 0,

    async execute(client, message, args, data) {
         const rankName = args.join(" ");
        if(!rankName) return message.channel.send(`specify a rankname`);
      
        RankSchema.findOne({ Guild: message.guild.id }), async (err, data) => {
            if (!data) return message.reply(`rank doesnt exists`)
            message.member.roles.add(data.Role);
            return message.channel.send(`You have revieved the role <@&${data.Role}>`)
        }
    }
}
