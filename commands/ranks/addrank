const RankSchema = require('../../models/ranks')

module.exports = {
    name: "addrank",
    description: "Shows your text as Clyde\'s message",
    usage: "clyde <text>",
    enabled: true,
    aliases: [],
    category: "Fun",
    memberPermissions: ["MANAGE_ROLES"],
    botPermissions: ["SEND_MESSAGES", "EMBED_LINKS", "MANAGE_ROLES"],
    //Settings for command
    nsfw: false,
    ownerOnly: false,
    cooldown: 0,

    async execute(client, message, args, data) {

        const role = message.mentions.roles.first();
        const rankName = args.slice(1).join(" ")

        if (!role) return message.reply('specify role!')
        if (!rankName) return message.reply('specify rank name!')
        await RankSchema.findOne({ Guild: message.guild.id, Rank: rankName }), async (err, data) => {
            if (data) return message.channel.send("This rank already exists!");
            else {
                data = new RankSchema({
                    Guild: message.channel.id,
                    Rank: rankName,
                    Role: role.id,
                });
                data.save();
                message.channel.send(`${role} is a new rank -> ${rankName}`)
            }
        }
    }
}